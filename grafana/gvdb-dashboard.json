{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "title": "Request Rates",
      "type": "row"
    },
    {
      "title": "Total QPS",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(gvdb_insert_requests_total[1m])) + sum(rate(gvdb_search_requests_total[1m])) + sum(rate(gvdb_get_requests_total[1m])) + sum(rate(gvdb_delete_requests_total[1m]))", "legendFormat": "QPS" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 5000 }] } } }
    },
    {
      "title": "Insert RPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 5, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(gvdb_insert_requests_total{status=\"success\"}[1m])) by (collection)", "legendFormat": "{{collection}} ok" },
        { "expr": "sum(rate(gvdb_insert_requests_total{status=\"error\"}[1m])) by (collection)", "legendFormat": "{{collection}} err" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Search RPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 5, "x": 9, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(gvdb_search_requests_total{status=\"success\"}[1m])) by (collection)", "legendFormat": "{{collection}} ok" },
        { "expr": "sum(rate(gvdb_search_requests_total{status=\"error\"}[1m])) by (collection)", "legendFormat": "{{collection}} err" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Get RPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 5, "x": 14, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(gvdb_get_requests_total{status=\"success\"}[1m])) by (collection)", "legendFormat": "{{collection}} ok" },
        { "expr": "sum(rate(gvdb_get_requests_total{status=\"error\"}[1m])) by (collection)", "legendFormat": "{{collection}} err" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Delete RPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 5, "x": 19, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(gvdb_delete_requests_total{status=\"success\"}[1m])) by (collection)", "legendFormat": "{{collection}} ok" },
        { "expr": "sum(rate(gvdb_delete_requests_total{status=\"error\"}[1m])) by (collection)", "legendFormat": "{{collection}} err" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "title": "Error Rates",
      "type": "row"
    },
    {
      "title": "Insert Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(gvdb_insert_requests_total{status=\"success\"}[5m])) / sum(rate(gvdb_insert_requests_total[5m])) * 100", "legendFormat": "Insert" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 }] } } }
    },
    {
      "title": "Search Success Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(gvdb_search_requests_total{status=\"success\"}[5m])) / sum(rate(gvdb_search_requests_total[5m])) * 100", "legendFormat": "Search" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 }] } } }
    },
    {
      "title": "Errors by Operation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(gvdb_insert_requests_total{status=\"error\"}[1m]))", "legendFormat": "Insert" },
        { "expr": "sum(rate(gvdb_search_requests_total{status=\"error\"}[1m]))", "legendFormat": "Search" },
        { "expr": "sum(rate(gvdb_get_requests_total{status=\"error\"}[1m]))", "legendFormat": "Get" },
        { "expr": "sum(rate(gvdb_delete_requests_total{status=\"error\"}[1m]))", "legendFormat": "Delete" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars" } } }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "title": "Latency (p50 / p95 / p99)",
      "type": "row"
    },
    {
      "title": "Insert Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gvdb_insert_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(gvdb_insert_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(gvdb_insert_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Search Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(gvdb_search_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(gvdb_search_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(gvdb_search_duration_seconds_bucket[1m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Get / Delete / Update Latency (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(gvdb_get_duration_seconds_bucket[1m])) by (le))", "legendFormat": "Get p99" },
        { "expr": "histogram_quantile(0.99, sum(rate(gvdb_delete_duration_seconds_bucket[1m])) by (le))", "legendFormat": "Delete p99" },
        { "expr": "histogram_quantile(0.99, sum(rate(gvdb_update_metadata_duration_seconds_bucket[1m])) by (le))", "legendFormat": "Update p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "title": "System Health",
      "type": "row"
    },
    {
      "title": "Collections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "gvdb_collection_count", "legendFormat": "Collections" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "title": "Total Vectors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(gvdb_vector_count)", "legendFormat": "Vectors" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "title": "Vectors per Collection",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "gvdb_vector_count", "legendFormat": "{{collection}}" }]
    },
    {
      "title": "Insert Throughput (vectors/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(gvdb_insert_vectors_total[1m])) by (collection)", "legendFormat": "{{collection}}" }],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["gvdb", "vector-database"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "GVDB Overview",
  "uid": "gvdb-overview",
  "version": 1
}
